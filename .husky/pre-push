#!/bin/sh

echo "--- Frontend build ---"
cd "$(dirname "$0")/.."
npm run build
if [ $? -ne 0 ]; then
  echo "FAILED: Frontend build"
  exit 1
fi
echo "PASSED: Frontend build"

BACKEND_DIR="$(dirname "$0")/../backend"
if [ -f "$BACKEND_DIR/package.json" ]; then
  echo "--- Backend build ---"
  cd "$BACKEND_DIR"
  npm run build
  if [ $? -ne 0 ]; then
    echo "FAILED: Backend build"
    exit 1
  fi
  echo "PASSED: Backend build"
fi

CONTRACTS_DIR="$(dirname "$0")/../contracts"
if [ -f "$CONTRACTS_DIR/Cargo.toml" ]; then
  echo "--- Contract build + tests ---"
  cd "$CONTRACTS_DIR"
  cargo build --release && cargo test
  if [ $? -ne 0 ]; then
    echo "FAILED: Contract build + tests"
    exit 1
  fi
  echo "PASSED: Contract build + tests"
fi
