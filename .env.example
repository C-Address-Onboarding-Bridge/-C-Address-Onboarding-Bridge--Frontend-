# Network Configuration
# Set to PUBLIC, TESTNET, or SANDBOX
NEXT_PUBLIC_NETWORK=SANDBOX

# Horizon URL (for sandbox, use localhost)
NEXT_PUBLIC_HORIZON_URL=http://localhost:8000

# Soroban RPC URL (for sandbox, use localhost)
NEXT_PUBLIC_SOROBAN_RPC_URL=http://localhost:8000/soroban/rpc

# Friendbot URL (for sandbox, use localhost)
NEXT_PUBLIC_FRIENDBOT_URL=http://localhost:8000/friendbot

# Bridge Contract ID (set when a bridge contract is deployed)
NEXT_PUBLIC_BRIDGE_CONTRACT_ID=
